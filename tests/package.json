    "test:e2e:brownfield": "RUN_LLM_E2E=1 RUN_LLM_E2E_FULL=1 vitest run e2e/brownfield.test.ts",
    "test:e2e:sudoku": "RUN_LLM_E2E=1 RUN_LLM_E2E_FULL=1 vitest run e2e/sudoku.test.ts",
