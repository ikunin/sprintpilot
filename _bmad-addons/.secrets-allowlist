# Patterns and paths exempt from secrets scanning
# One pattern per line. Supports glob syntax.

# Test files commonly contain mock secrets
test/**
tests/**
**/test_*
**/*_test.*
**/*_spec.*
spec/**

# Example/template files
*.example
*.sample
*.template
.env.example
.env.sample

# Documentation
docs/**
*.md

# Fixture/mock data
**/fixtures/**
**/mocks/**
**/testdata/**
