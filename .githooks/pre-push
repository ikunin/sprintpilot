#!/usr/bin/env bash
# Sprintpilot pre-push hook
# Mirrors the GitHub Actions `CI` workflow (.github/workflows/ci.yml) so that
# broken pushes are rejected locally before they ever reach CI.
#
# Ordered checks:
#   1. Biome CI mode — format + lint, strict
#   2. Fast test suite — unit + scripts (same as CI)
#
# Enable once per clone (auto-run by `npm install` via the `prepare` script):
#   git config core.hooksPath .githooks
#
# Bypass in emergencies:
#   git push --no-verify

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Install test devDependencies (Biome + vitest) if missing.
if [ ! -x tests/node_modules/.bin/biome ]; then
  echo "pre-push: installing test devDependencies (cd tests && npm install)..."
  (cd tests && npm install --silent)
fi

echo "pre-push: biome ci ."
./tests/node_modules/.bin/biome ci . || {
  echo ""
  echo "✗ Biome found errors. Auto-fix: ./tests/node_modules/.bin/biome check --write ."
  exit 1
}

# Run the fast suite with an empty global git config so scratch test repos
# don't inherit a developer's commit.gpgsign / user.signingkey — otherwise
# the dozens of createTempRepo() calls in scripts/ tests all fail trying to
# sign their initial empty commit. CI runners never have these settings;
# this just makes local dev reproducible under the same conditions.
echo "pre-push: running fast test suite"
(
  cd tests
  GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null npm run test:fast --silent
) || {
  echo ""
  echo "✗ Test suite failed. Fix tests before pushing."
  exit 1
}

echo "pre-push: ✓ all checks passed"
